# =========================
# HumAIne API configuration
# =========================

# Base URL for the HumAIne MinIO / API service
HUMAINE_API_BASE_URL=https://humain e-minio-api.example.net

# Timeout for API requests (in seconds)
HUMAINE_API_TIMEOUT=30

# =========================
# Authentication credentials
# =========================

# API username (provided by HumAIne / project admin)
HUMAINE_API_USERNAME=your-username-here

# API password or token
HUMAINE_API_PASSWORD=your-password-here
